{
    "ver": "1.1",
    "authors": [
        "ac.shahnam, cashahnam"
    ],
    "contact": "you@your.org",
    "categories": [
        "active",
        "assembly",
        "ont"
    ],
    "widgets": {
        "input": null,
        "output": ""
    },
    "job_id_output_field": "docker",
    "parameters": [
        {
            "id": "reads_ref",
            "optional": false,
            "advanced": false,
            "allow_multiple": false,
            "default_values": [
                ""
            ],
            "field_type": "text",
            "text_options": {
                "valid_ws_types": [
                    "KBaseSets.ReadsSet",
                    "KBaseFile.SingleEndLibrary",
                    "KBaseFile.PairedEndLibrary",
                    "KBaseAssembly.SingleEndLibrary",
                    "KBaseAssembly.PairedEndLibrary"
                ]
            }
        },
        {
            "id": "output_assembly_name",
            "optional": false,
            "advanced": false,
            "allow_multiple": false,
            "default_values": [
                "raven_assembly"
            ],
            "field_type": "text",
            "text_options": {
                "valid_ws_types": [
                    "KBaseGenomeAnnotations.Assembly"
                ],
                "is_output_name": true,
                "placeholder": ".Raven"
            }
        },
        {
            "id": "emit_gfa",
            "optional": true,
            "advanced": false,
            "allow_multiple": false,
            "default_values": [
                "1"
            ],
            "field_type": "checkbox",
            "checkbox_options": {
                "checked_value": "1",
                "unchecked_value": "0"
            }
        }
    ],
    "behavior": {
        "service-mapping": {
            "url": "",
            "name": "kb_raven",
            "method": "run_kb_raven",
            "input_mapping": [
                {
                    "narrative_system_variable": "workspace",
                    "target_property": "workspace_name"
                },
                {
                    "narrative_system_variable": "workspace_id",
                    "target_property": "workspace_id"
                },
                {
                    "input_parameter": "reads_ref",
                    "target_property": "reads_ref",
                    "target_type_transform": "resolved-ref"
                },
                {
                    "input_parameter": "output_assembly_name",
                    "target_property": "output_assembly_name"
                },
                {
                    "input_parameter": "emit_gfa",
                    "target_property": "emit_gfa"
                }
            ],
            "output_mapping": [
                {
                    "service_method_output_path": [
                        0,
                        "report_name"
                    ],
                    "target_property": "report_name"
                },
                {
                    "service_method_output_path": [
                        0,
                        "report_ref"
                    ],
                    "target_property": "report_ref"
                }
            ]
        }
    }
}
